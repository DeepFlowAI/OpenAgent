NEXT_PUBLIC_API_URL=http://localhost:5001/api/

# Server-side base URL used by the visitor site (Help Center SSR routes
# under /hc/*) to call the backend from within the Next.js server runtime.
# In Docker / k8s this is typically the internal service DNS name.
BACKEND_URL=http://localhost:5001

# Public default docs host used by visitor-site SSR routes to compose
# canonical / Open Graph / sitemap URLs. Host only — no scheme, no trailing
# slash. Must match the backend's PUBLIC_DOCS_HOST. Leave empty in local dev
# to disable canonical / OG URLs in generated metadata.
PUBLIC_DOCS_HOST=

# AGPLv3 §13: where users running this build can obtain the corresponding
# source code. Defaults to the upstream public repo; set this to your fork
# / mirror URL when distributing a modified build.
NEXT_PUBLIC_SOURCE_URL=https://github.com/DeepFlowAI/OpenAgent

# Optional (local only): PyPI API token for packaging uploads — never commit real values.
