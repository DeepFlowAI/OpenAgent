APP_NAME=OpenAgent
APP_VERSION=0.1.0
DEBUG=false

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/openagent
AUTO_MIGRATE=true

REDIS_URL=redis://:password@localhost:6379/0

SECRET_KEY=your-secret-key

# Optional: comma-separated frontend origins for strict CORS.
# Leave empty to allow any origin without credentials (typical for JWT in Authorization).
# CORS_ALLOW_ORIGINS=https://openagent.example.com,https://newagent.example.com
# CORS_ALLOW_CREDENTIALS=false

# Tenant Platform API Key (used by Tenant Platform to manage tenants via X-API-Key header)
TENANT_PLATFORM_API_KEY=your-tenant-platform-api-key

SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=your-email@163.com

# OpenRouter (LiteLLM) — agent chat
OPENROUTER_API_KEY=
# Override only when routing through a private OpenRouter proxy / mirror.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Alibaba Bailian (OpenAI-compatible) — preferred for supported domestic models
ALIYUN_BAILIAN_API_KEY=
ALIYUN_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MiniMax official API — reserved for direct MiniMax provider access
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Moonshot / Kimi official API
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# Zhipu official API
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_NUM_RETRIES=2
# LLM_REQUEST_TIMEOUT_SEC=

# Stream-level reliability (stream-level retry spec) — three-stage timeouts + auto retries on top of LiteLLM's
# request-level retries, so stalled / half-broken upstream streams don't surface as "stuck spinner".
# LLM_STREAM_RETRY_ENABLED=true
# LLM_FIRST_CHUNK_TIMEOUT_SEC=30
# LLM_IDLE_TIMEOUT_SEC=15
# LLM_HARD_TIMEOUT_SEC=180
# LLM_STREAM_RETRY_MAX=2
# LLM_STREAM_RETRY_BACKOFF_SEC=0.5
# LLM_STREAM_RESET_MAX_CHARS=50

# ── Observability (OTLP / OpenTelemetry) ──
# Set OBSERVABILITY_BACKEND=otel to enable shipping logs/traces to a remote system.
# The exporter speaks standard OTLP/HTTP, so any compatible backend works
# (SigNoz, Honeycomb, Tempo, Grafana Cloud, …) — only the
# endpoint + headers below need to change.
OBSERVABILITY_BACKEND=noop
OTEL_SERVICE_NAME=openagent-api
OTEL_DEPLOYMENT_ENVIRONMENT=dev
# Example for any OTLP-compatible backend (Grafana Cloud, self-hosted Loki/
# Tempo, SigNoz, vendor APMs, etc.):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-collector.example.com
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(user:password)>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
# Vendor extras (GreptimeDB-compatible pipelines etc.). Other backends can leave defaults.
OTEL_TRACES_PIPELINE_NAME=greptime_trace_v1
OTEL_LOGS_TABLE_NAME=otel_logs
# Capture full LLM request/response bodies as span attributes (off by default for PII).
OTEL_CAPTURE_LLM_CONTENT=false

# ── Help Center (3.6) ──
# Default platform docs host used by visitor URLs:
#   https://{PUBLIC_DOCS_HOST}/hc/{slug}/...
# Host only (no scheme, no trailing slash). Self-custom domains are out of scope this release.
PUBLIC_DOCS_HOST=docs.example.com
